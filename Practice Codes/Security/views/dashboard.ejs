<!DOCTYPE html>
<html>
<head>
    <title>Dashboard</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gradient-to-r from-blue-500 to-purple-600 min-h-screen flex items-center justify-center">

    <div class="bg-white p-8 rounded-2xl shadow-2xl w-96 text-center">

        <h2 class="text-2xl font-bold text-gray-800 mb-4">
            Dashboard 📊
        </h2>

        <!-- Welcome user -->
        <p class="text-gray-700 mb-6">
            Welcome, 
            <span class="font-semibold text-blue-600">
                <%= user.email %>
            </span> 👋
        </p>

        <!-- Some actions -->
        <div class="space-y-3">

            <a href="/"
               class="block w-full bg-gray-500 text-white py-2 rounded-lg hover:bg-gray-600 transition">
                Home
            </a>

            <a href="/logout"
               class="block w-full bg-red-500 text-white py-2 rounded-lg hover:bg-red-600 transition">
                Logout 🚪
            </a>

        </div>

    </div>

</body>
</html>